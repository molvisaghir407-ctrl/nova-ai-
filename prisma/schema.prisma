generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Settings {
  id               String   @id @default("nova-settings")
  wakeWord         String   @default("Hey Nova")
  voiceEnabled     Boolean  @default(true)
  ttsEnabled       Boolean  @default(true)
  ttsSpeed         Float    @default(1.0)
  ttsVoice         String   @default("default")
  theme            String   @default("dark")
  language         String   @default("en-US")
  proactiveEnabled Boolean  @default(true)
  offlineMode      Boolean  @default(false)
  logLevel         String   @default("info")
  safetyLevel      String   @default("balanced")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Memory {
  id          String   @id @default(cuid())
  category    String
  content     String
  importance  Float    @default(0.5)
  embedding   String?
  metadata    String?
  contentHash String?  @unique
  accessedAt  DateTime @default(now())
  accessCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([importance])
}

model Conversation {
  id        String    @id @default(cuid())
  title     String?
  summary   String?
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([createdAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  tokens         Int          @default(0)
  metadata       String?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  category    String
  enabled     Boolean  @default(true)
  config      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  category  String
  details   String?
  success   Boolean  @default(true)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([category])
  @@index([createdAt])
}

model Suggestion {
  id          String    @id @default(cuid())
  type        String
  trigger     String
  suggestion  String
  action      String?
  priority    Int       @default(5)
  enabled     Boolean   @default(true)
  lastShown   DateTime?
  shownCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([priority])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("pending")
  priority    Int       @default(5)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([dueDate])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
}
