# Nova AI — Environment Variables
# Fill in all values and import into Vercel dashboard

# ── Cloudflare (already provisioned) ─────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=fc278dd6b224f2c04eef385eaa66dcdd
CLOUDFLARE_D1_DATABASE_ID=ba92f281-23bf-4312-ad36-c4ca4683df57
CLOUDFLARE_D1_TOKEN=YOUR_CLOUDFLARE_API_TOKEN
CLOUDFLARE_KV_NAMESPACE_ID=cbb6c3599af44d8c8b5990bfea17eda6

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=file:/tmp/nova.db

# ── API Protection ────────────────────────────────────────────────────────────
NOVA_API_KEY=YOUR_NOVA_API_KEY
NEXT_PUBLIC_NOVA_API_KEY=YOUR_NOVA_API_KEY

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET
NEXTAUTH_URL=https://your-app.vercel.app

# ── NVIDIA NIM Universal API ──────────────────────────────────────────────────
# Get your key at: https://build.nvidia.com → API Keys
NVIDIA_NIM_API_KEY=YOUR_NVIDIA_NIM_API_KEY
NVIDIA_NIM_BASE=https://integrate.api.nvidia.com/v1

# Chat model — Kimi K2 thinking (default)
NVIDIA_NIM_MODEL=moonshotai/kimi-k2-instruct

# Vision model — choose one:
#   meta/llama-3.2-90b-vision-instruct   (best quality)
#   nvidia/llama-3.2-11b-vision-instruct (faster/cheaper)
NVIDIA_NIM_VISION_MODEL=meta/llama-3.2-90b-vision-instruct

# Image generation model — choose one:
#   black-forest-labs/flux-dev      (best quality)
#   black-forest-labs/flux-schnell  (fastest)
#   stabilityai/stable-diffusion-xl
NVIDIA_NIM_IMAGE_MODEL=black-forest-labs/flux-dev

# ── ZAI SDK (ASR + TTS — NVIDIA NIM has no speech APIs) ───────────────────────
# ZAI is auto-configured, no key needed unless self-hosting

NODE_ENV=production
